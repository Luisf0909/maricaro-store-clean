# Dockerfile.node — starting point for a Node.js service.
# Tweak: NODE_VERSION, package manager (npm/pnpm/yarn), PORT, start command.
#
# This is a two-stage build: deps/build in one layer, slim runtime in another.
# Good defaults: non-root user, no dev deps in final image, cache-friendly layer order.

ARG NODE_VERSION=20

# ---- Stage 1: build ----
FROM node:${NODE_VERSION}-slim AS build

WORKDIR /app

# Copy lockfile and manifest first so `npm ci` layer caches when source changes.
COPY package.json package-lock.json* pnpm-lock.yaml* yarn.lock* ./

# Install deps — use the lockfile-strict variant of your package manager.
# Pick one (uncomment), delete the others:
RUN npm ci --include=dev
# RUN corepack enable && pnpm install --frozen-lockfile
# RUN corepack enable && yarn install --immutable

COPY . .

# Build step (adjust for your framework):
RUN npm run build

# ---- Stage 2: runtime ----
FROM node:${NODE_VERSION}-slim AS runtime

ENV NODE_ENV=production
WORKDIR /app

# Prod-only deps
COPY package.json package-lock.json* pnpm-lock.yaml* yarn.lock* ./
RUN npm ci --omit=dev && npm cache clean --force
# RUN corepack enable && pnpm install --prod --frozen-lockfile
# RUN corepack enable && yarn workspaces focus --production

# Copy build artifacts from the build stage
COPY --from=build /app/dist ./dist
# For Next.js: COPY --from=build /app/.next ./.next + COPY --from=build /app/public ./public

# Drop root
RUN groupadd --system --gid 1001 nodejs \
 && useradd --system --uid 1001 --gid nodejs nextjs \
 && chown -R nextjs:nodejs /app
USER nextjs

EXPOSE 3000

# Bind 0.0.0.0, read PORT from the host (Railway, Fly, compose all inject it).
ENV PORT=3000
CMD ["node", "dist/server.js"]
