# .env.example — commit this file. Copy to .env (NEVER commit .env) and fill
# in real values for local dev. For production, push values to the target's
# secret store (see references/env-mapping.md).
#
# Conventions:
# - UPPERCASE_WITH_UNDERSCORES.
# - Group by concern: runtime, database, third-party APIs, feature flags.
# - Add a brief comment on the purpose of each var — helps new contributors.
# - Leave values empty (KEY=) or use obviously-fake placeholders (KEY=REPLACE_ME).
# - Never include real credentials, even in commits that are "just a rename."

# ---- Runtime ----
# NODE_ENV / PYTHON environment — usually set by the platform, not here.
# PORT           # usually injected by Railway / Fly / Docker

# ---- Database ----
DATABASE_URL=              # postgres://user:pass@host:5432/dbname
# REDIS_URL=               # redis://host:6379

# ---- LLM / AI ----
# ANTHROPIC_API_KEY=       # sk-ant-api03-...   (rotate on any suspected leak)
# OPENAI_API_KEY=          # sk-...              (rotate on any suspected leak)

# ---- Third-party ----
# STRIPE_SECRET_KEY=       # sk_live_... or sk_test_...
# SENTRY_DSN=              # https://<key>@<org>.ingest.sentry.io/<project>
# GITHUB_TOKEN=            # ghp_... or github_pat_...

# ---- Feature flags ----
# FEATURE_X_ENABLED=false

# ---- App-specific ----
# ADMIN_EMAIL=
# SESSION_SECRET=          # generate with `openssl rand -hex 32`
